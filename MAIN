local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local Gardens = workspace:WaitForChild("Gardens")

local KG_LIMIT = 15
local CHECK_DELAY = 1

local LastState = nil

-- Tunggu loading game
task.wait(15)

-- Cari plot milik player
local function GetMyPlot()
    for i = 1, 8 do
        local Plot = Gardens:FindFirstChild("Plot" .. i)

        if Plot and Plot:GetAttribute("Owner") == LocalPlayer.Name then
            return Plot
        end
    end

    return nil
end

while task.wait(CHECK_DELAY) do
    local Plot = GetMyPlot()

    if not Plot then
        continue
    end

    local HasPlantAbove15 = false

    for _, Plant in ipairs(Plot.Plants:GetChildren()) do
        if not Plant:FindFirstChild("Fruits") then
            local Part = Plant:FindFirstChild("1")

            if Part and Part:IsA("BasePart") then
                local KG = Part.Size.X * 1.067

                if KG > KG_LIMIT then
                    HasPlantAbove15 = true
                    break
                end
            end
        end
    end

    if LastState ~= HasPlantAbove15 then
        LastState = HasPlantAbove15

        if HasPlantAbove15 then
            task.spawn(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/juraganzenx/CARROTEVENT/refs/heads/main/DISCONECTEDIFNOTGOLD"))()
            end)

            task.spawn(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/juraganzenx/HUB2/refs/heads/main/DESTROYPLOT"))()
            end)

        else

            task.spawn(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/juraganzenx/CARROTEVENT/refs/heads/main/DISCONECTEDIFNOTGOLD"))()
            end)

            task.spawn(function()
                loadstring(game:HttpGet("https://raw.githubusercontent.com/juraganzenx/HUB2/refs/heads/main/DESTROYPLOT"))()
            end)

        end
    end
end
