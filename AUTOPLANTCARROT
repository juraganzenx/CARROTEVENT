--------------------------------------------------
-- FUNCTIONS
--------------------------------------------------

local function GetMyPlot()
    local PlotId = LocalPlayer:GetAttribute("PlotId")
    if not PlotId then
        return nil
    end

    return workspace.Gardens:FindFirstChild("Plot" .. PlotId)
end

local function CountGoldPlants()
    local Plot = GetMyPlot()
    if not Plot then
        Label.Text = "Gold: 0/" .. MAX_GOLD
        return 0
    end

    local Plants = Plot:FindFirstChild("Plants")
    if not Plants then
        Label.Text = "Gold: 0/" .. MAX_GOLD
        return 0
    end

    local Count = 0

    for _, Plant in ipairs(Plants:GetChildren()) do
        if Plant:GetAttribute("Mutation") == "Gold" then
            Count += 1
        end
    end

    Label.Text = ("Gold: %d/%d"):format(Count, MAX_GOLD)

    if Count >= MAX_GOLD then
        Label.TextColor3 = Color3.fromRGB(255, 80, 80)
    else
        Label.TextColor3 = Color3.fromRGB(80, 255, 80)
    end

    return Count
end

