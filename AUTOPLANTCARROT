--------------------------------------------------

repeat
    task.wait()
until GetMyPlot()

local Plot = GetMyPlot()

Plot:WaitForChild("Visual")
Plot.Visual:WaitForChild("BedSection")

local BottomFace = Plot.Visual.BedSection:WaitForChild("BottomFace")
--------------------------------------------------
-- CIRCLE PLANT POSITION
--------------------------------------------------

local POINTS_PER_RING = 5
local MAX_RING = 8 -- hanya gunakan 5 ring
local RADIUS_STEP = 0.55
local START_RADIUS = 0.5

local PlantIndex = 0

local function GetNextPlantPosition()

    local MaxPoints = POINTS_PER_RING * MAX_RING

    if PlantIndex >= MaxPoints then
        PlantIndex = 0
    end

    local Ring = math.floor(PlantIndex / POINTS_PER_RING)
    local Index = PlantIndex % POINTS_PER_RING

    local Radius = START_RADIUS + (Ring * RADIUS_STEP)
    local Angle = math.rad((360 / POINTS_PER_RING) * Index)

    local LocalPos = Vector3.new(
        math.cos(Angle) * Radius,
        0,
        math.sin(Angle) * Radius
    )

    PlantIndex += 1

    return BottomFace.CFrame:PointToWorldSpace(LocalPos)
end

local Plants = Plot:WaitForChild("Plants")

-- Tunggu sampai minimal ada 1 plant (maksimal 10 detik)
local Start = os.clock()

while #Plants:GetChildren() == 0 and os.clock() - Start < 10 do
    task.wait(0.25)
end

print("Plot Loaded!")

--------------------------------------------------
-- AUTO PLANT
--------------------------------------------------

while task.wait(0.1) do

    if not AutoPlant then
        continue
    end

    local GoldCount = CountGoldPlants()

    if GoldCount >= MAX_GOLD then
        continue
    end

    local Character = LocalPlayer.Character
    local Backpack = LocalPlayer:FindFirstChild("Backpack")

    if not Character or not Backpack then
        continue
    end

    -- Cari Gold Seed
    local Tool = Character:FindFirstChild(SEED_NAME)

    if not Tool then
        Tool = Backpack:FindFirstChild(SEED_NAME)

        if Tool and Tool:IsA("Tool") then
            Tool.Parent = Character
            task.wait(0.2)
        end
    end

    if not Tool then
        continue
    end

    local SeedTool = Tool:GetAttribute("SeedTool")
    if not SeedTool then
        continue
    end

    local PlantPos = GetNextPlantPosition()

    Networking.Plant.PlantSeed:Fire(
        PlantPos,
        SeedTool,
        Tool
    )
end
