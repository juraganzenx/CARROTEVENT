local Players = game:GetService("Players")

local function checkGoldMoon()
    if not workspace:FindFirstChild("Goldmoon") then
        Players.LocalPlayer:Kick("Gold Moon tidak aktif. Disconnecting...")
    end
end

-- Cek saat script dijalankan
checkGoldMoon()

-- Pantau jika Goldmoon dihapus dari Workspace
workspace.ChildRemoved:Connect(function(child)
    if child.Name == "Goldmoon" then
        Players.LocalPlayer:Kick("Gold Moon telah berakhir. Disconnecting...")
    end
end)
