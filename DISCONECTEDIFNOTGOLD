local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

-- CONFIG
local START_DELAY = 15      -- Tunggu game selesai loading
local CHECK_DELAY = 1        -- Interval pengecekan

task.wait(START_DELAY)

while task.wait(CHECK_DELAY) do
    local HasGoldMoon = workspace:FindFirstChild("Goldmoon")
    local HasRainbowMoon = workspace:FindFirstChild("RainbowMoon")

    if not HasGoldMoon and not HasRainbowMoon then
        LocalPlayer:Kick("Gold Moon / Rainbow Moon tidak aktif. Disconnecting...")
        break
    end
end
