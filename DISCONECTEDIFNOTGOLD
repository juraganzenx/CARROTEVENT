local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

-- CONFIG
local START_DELAY = 15 -- Tunggu game loading
local CHECK_DELAY = 1  -- Interval pengecekan

task.wait(START_DELAY)

while task.wait(CHECK_DELAY) do
    local DisconnectReason = nil

    -- Bloodmoon
    if workspace:FindFirstChild("ActiveBloodmoon") then
        DisconnectReason = "Bloodmoon"
    end

    -- Aurora
    if workspace:GetAttribute("AuroraEvent") then
        DisconnectReason = "Aurora"
    end

    -- Lightning
    if workspace:FindFirstChild("WeatherEffects")
        and workspace.WeatherEffects:FindFirstChild("LightningStrike") then
        DisconnectReason = "Lightning"
    end

    -- Snowfall (Blizzard)
    if workspace:FindFirstChild("ActiveBlizzard") then
        DisconnectReason = "Snowfall (Blizzard)"
    end

    -- Starfall
    if workspace:GetAttribute("ShootingStarEvent") then
        DisconnectReason = "Starfall"
    end

    -- Sunburst
    if workspace:GetAttribute("SunburstEvent") then
        DisconnectReason = "Sunburst"
    end

    if DisconnectReason then
        LocalPlayer:Kick("Weather terdeteksi: " .. DisconnectReason .. ". Disconnecting...")
        break
    end
end
