local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

-- CONFIG
local START_DELAY = 15      -- Tunggu game selesai loading
local CHECK_DELAY = 1        -- Interval pengecekan

task.wait(START_DELAY)

while task.wait(CHECK_DELAY) do
    if not workspace:FindFirstChild("Goldmoon") then
        LocalPlayer:Kick("Gold Moon tidak aktif. Disconnecting...")
        break
    end
end
